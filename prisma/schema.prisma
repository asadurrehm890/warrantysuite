// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
}

model PurchaseSource {
  id        String   @id @default(cuid())
  shop      String
  label     String
  createdAt DateTime @default(now())

  @@index([shop])
}

model WarrantySettings {
  shop               String   @id
  marketingText      String?
  claimMarketingText String?

  // brevoApiKey and cloudinarySecret are stored AES-256-GCM encrypted
  // (see app/utils/crypto.server.js). brevoSenderEmail / cloudName /
  // cloudinaryKey are non-secret identifiers and stored plaintext.
  brevoApiKey      String?
  brevoSenderEmail String?

  cloudName         String?
  cloudinaryKey     String?
  cloudinarySecret  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model OtpToken {
  token     String   @id
  shop      String
  email     String
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([shop, email])
  @@index([expiresAt])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  shop        String
  type        String   // warranty_approved, warranty_disapproved, claim_approved, claim_rejected
  subject     String
  htmlContent String   // PostgreSQL TEXT type
  textContent String   // PostgreSQL TEXT type
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shop, type])
}